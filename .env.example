# Used only when no restaurants have coordinates yet.
NEXT_PUBLIC_MAP_CENTER_LAT=29.9012
NEXT_PUBLIC_MAP_CENTER_LNG=-81.3124

# Nominatim (https://nominatim.openstreetmap.org/) — required style: app name + contact URL or email.
# Example: MyTownHH/1.0 (https://yoursite.example/contact)
NOMINATIM_USER_AGENT=

# Optional. Appended to the address string for geocoding (default: ", St. Augustine, FL, USA").
# NOMINATIM_REGION_SUFFIX=
